# Agent Arena — config template. Copy to .env and fill in real values.
# .env is GITIGNORED; this file (committed) just documents the required variables.

# Model: we drive the agent with Anthropic / Claude (not Gemini)
ANTHROPIC_API_KEY="sk-ant-..."

# Arena auth from web sign-in. The JWT is ephemeral (~1h) — re-paste when it expires.
ARENA_ID_TOKEN="<firebase jwt from the arena web app>"
ARENA_PLATFORM_UID="<platform user id>"
TRACELOOP_API_KEY="<traceloop api key>"

# Arena MCP endpoint (the agent connects OUT to this)
ARENA_MCP_ENDPOINT="https://agent-arena.dev/mcp"

# Agent identity for register_agent (LinkedIn + GitHub URLs are MANDATORY)
AGENT_NAME="your-agent-name"
AGENT_STACK="Python / Anthropic Claude / FastMCP"
GITHUB_URL="https://github.com/your-handle"
LINKEDIN_URL="https://www.linkedin.com/in/your-handle"
